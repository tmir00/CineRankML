# Postgres
POSTGRES_USER=cinerankml
POSTGRES_PASSWORD=cinerankml
POSTGRES_DB=cinerankml
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy connection URL for local host tools (uv run alembic, IDE, tests)
DATABASE_URL=postgresql+psycopg://cinerankml:cinerankml@localhost:5432/cinerankml

# Docker Compose runs migrations automatically via the migrate service.
# To apply new migrations after the first startup:
#   docker compose run --rm migrate

# Kafka (Phase 2)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_PORT=9092
RATINGS_TOPIC=ratings
TAGS_TOPIC=tags
RATINGS_CONSUMER_GROUP=ratings-consumer
TAGS_CONSUMER_GROUP=tags-consumer

# CSV producers (throttle + optional sample limit)
ROWS_PER_SECOND=1000
ROW_DELAY_SECONDS=1.5
PRODUCER_LOG_EVERY_N=1000
CHECKPOINT_EVERY_N=1000
# ROW_LIMIT=1000
CSV_PATH=/data/ratings.csv
# SOURCE_FILE=ratings.csv
START_ROW=0

# Worker metrics
METRICS_PORT=9100
WORKER_NAME=worker

# Phase 3 catalog jobs
TMDB_API_KEY=
TMDB_REQUESTS_PER_SECOND=3
ENRICHMENT_BATCH_SIZE=50
ENRICHMENT_LOG_EVERY_N=100
# ENRICHMENT_LIMIT=100
MOVIES_CSV_PATH=/data/movies.csv
LINKS_CSV_PATH=/data/links.csv
SEED_BATCH_SIZE=1000

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Phase 4 OpenSearch sync
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX_ALIAS=movies
OPENSEARCH_BULK_BATCH_SIZE=100
EMBEDDER_BASE_URL=http://localhost:8080
EMBEDDING_VERSION=content-v1
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_TEXT_TEMPLATE_VERSION=v1
SYNC_BATCH_SIZE=50
SYNC_LOG_EVERY_N=100
REBUILD_INDEX=false
# SYNC_LIMIT=100

# Phase 5 snapshots
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cinerankml
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SNAPSHOT_BATCH_SIZE=50000
PUSHGATEWAY_URL=http://localhost:9091
METRICS_JOB_NAME=s3_snapshot
# SNAPSHOT_ID=2026-06-25T120000Z

# Phase 6 CF dataset prep
CF_SHUFFLE_SEED=42
CF_TRAIN_FRACTION=0.8
CF_VALIDATION_FRACTION=0.1
CF_TEST_FRACTION=0.1
CF_PART_ROW_LIMIT=500000
CF_DATASET_METRICS_JOB_NAME=prepare_cf_dataset
# CF_DATASET_VERSION=2026-06-25T121500Z

# Phase 7 collaborative filtering training
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=collaborative_filtering
CF_EMBEDDING_DIM=64
CF_EPOCHS=20
CF_BATCH_SIZE=4096
CF_LEARNING_RATE=0.01
CF_EARLY_STOPPING_PATIENCE=3
CF_DEVICE=auto
CF_METRICS_JOB_NAME=train_cf
# CF_DATASET_VERSION=2026-06-25T121500Z
# CF_VERSION=cf-v1-2026-06-25T122000Z

# Phase 2 smoke test:
#   ROW_LIMIT=1000 docker compose --profile stream up --build
